# =============================================================================
# WEB APP — copy to .env and fill in your secrets
#   cp .env.example .env
#
# Safe to commit:  .env.example
# Never commit:     .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# Use DATABASE_URL for local dev, DATABASE_URL_PROD when running with Docker.

# Local development (npm run dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamTaskManagementProdDb

# Docker / production (docker compose up)
DATABASE_URL_PROD=postgresql://postgres:postgres@postgres:5432/teamTaskManagementProdDb

# --- Authentication ----------------------------------------------------------
# Generate AUTH_SECRET: openssl rand -base64 32

AUTH_SECRET=replace-with-a-long-random-string
AUTH_URL=http://localhost:3000

# GitHub — callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Google — callback: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# --- Socket ------------------------------------------------------------------
# Browser always uses localhost. Server uses socket hostname inside Docker.

NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_URL=http://localhost:3001
