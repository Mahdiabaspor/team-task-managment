# =============================================================================
# WEB APP — Environment variables
# =============================================================================
#
# 1. Copy this file to .env:
#      cp .env.example .env
#
# 2. Fill in your real values in .env (never commit .env to GitHub!)
#
# 3. Use different DATABASE_URL depending on how you run the app:
#      - Docker:      @postgres:5432
#      - Local dev:   @localhost:5432
#
# =============================================================================

# --- Database ----------------------------------------------------------------

# PostgreSQL connection string

# Local dev: 
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamTaskManagementProdDb



# Docker:  
DATABASE_URL_PROD=postgresql://postgres:postgres@postgres:5432/teamTaskManagementProdDb

# --- Authentication (NextAuth) -----------------------------------------------

# Random secret for encrypting sessions
# Generate one with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string

# Public URL where users open your app in the browser
AUTH_URL=http://localhost:3000

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Google OAuth — https://console.cloud.google.com/
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# --- Socket (real-time updates) ----------------------------------------------

# URL the BROWSER uses to connect to the socket server
# Always use localhost when you open the app on your machine
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# URL the WEB SERVER uses to talk to the socket server
# Docker:    http://socket:3001
# Local dev: http://localhost:3001
SOCKET_URL=http://localhost:3001
