# =============================================================================
# SOCKET SERVER — Environment variables
# =============================================================================
#
# 1. Copy this file to .env:
#      cp .env.example .env
#
# 2. Fill in your real values in .env (never commit .env to GitHub!)
#
# =============================================================================

# --- Server ------------------------------------------------------------------

# Port the socket server listens on
PORT=3001

# --- CORS --------------------------------------------------------------------

# URL of your web app as seen in the BROWSER (the origin users visit)
# This must match where you open the site, e.g. http://localhost:3000
# Do NOT use Docker internal names like http://web:3000
WEB_URL=http://localhost:3000
